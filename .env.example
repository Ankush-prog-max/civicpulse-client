# Google OAuth Client ID, for "Sign in with Google" button on Login/Register pages.
# Get one free at https://console.cloud.google.com/apis/credentials
# Must be the SAME Client ID configured on the backend (server/.env -> GOOGLE_CLIENT_ID).
# Leave blank to hide the Google button entirely — email/password login still works fully.
VITE_GOOGLE_CLIENT_ID=

# Backend API base URL. Leave blank for local dev (Vite's proxy handles it — see vite.config.js).
# For production on Vercel, set this to your deployed backend's URL + /api,
# e.g. https://civicpulse-api.vercel.app/api
VITE_API_BASE_URL=
